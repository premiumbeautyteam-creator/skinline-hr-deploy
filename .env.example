# SkinLine HR CRM — environment template
# Copy to .env and fill in real values. NEVER commit the real .env.

# --- Core ---
NODE_ENV=production
PORT=3000
PUBLIC_URL=https://app.skinline-hr.ru
API_URL=https://api.skinline-hr.ru
SESSION_SECRET=

# Database (PostgreSQL in production; SQLite data.db used as fallback)
DATABASE_URL=postgres://skinline:CHANGE_ME@127.0.0.1:5432/skinline_hr

# --- Token encryption (AES-256-GCM) ---
# Generate with: openssl rand -hex 32   (must be 64 hex chars / 32 bytes)
ENCRYPTION_KEY=

# --- hh.ru integration (OAuth) ---
# Created in the hh.ru employer developer cabinet.
HH_CLIENT_ID=
HH_CLIENT_SECRET=
# Must EXACTLY match the redirect_uri registered in the hh.ru cabinet.
HH_REDIRECT_URI=https://api.skinline-hr.ru/api/integrations/hh/callback
# Employer id (optional — resolved automatically from the connected account when empty).
HH_EMPLOYER_ID=

# --- Avito integration ---
AVITO_CLIENT_ID=
AVITO_CLIENT_SECRET=
AVITO_WEBHOOK_SECRET=

# --- Telegram bot ---
TELEGRAM_BOT_TOKEN=

# --- AI (OpenRouter) ---
CUSTOM_CRED_OPENROUTER_AI_TOKEN=
